{
  "name": "payment-gateway-tests",
  "version": "1.0.0",
  "description": "Payment Gateway Testing Suite",
  "scripts": {
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "test:debug": "node --inspect-brk node_modules/.bin/jest --runInBand",
    "test:integration": "jest --testPathPattern=integration",
    "test:unit": "jest --testPathPattern=unit",
    "local:start": "docker-compose up -d",
    "local:stop": "docker-compose down",
    "local:logs": "docker-compose logs -f",
    "local:test": "jest --testPathPattern=local"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "lambda_functions/**/*.{js,mjs}",
      "!lambda_functions/**/*.test.js"
    ],
    "testMatch": [
      "**/test/**/*.test.js",
      "**/?(*.)+(spec|test).js"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 70,
        "functions": 70,
        "lines": 70,
        "statements": 70
      }
    },
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.mjs$": "$1"
    },
    "transform": {
      "^.+\\.mjs?$": "babel-jest"
    }
  },
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@babel/preset-env": "^7.23.0",
    "babel-jest": "^29.7.0",
    "jest": "^29.7.0",
    "aws-sdk-client-mock": "^3.0.0",
    "aws-sdk-client-mock-es": "^3.0.0"
  },
  "dependencies": {
    "@aws-sdk/client-secrets-manager": "^3.400.0",
    "@aws-sdk/client-dynamodb": "^3.400.0",
    "@aws-sdk/client-s3": "^3.400.0",
    "@aws-sdk/lib-dynamodb": "^3.400.0"
  }
}
